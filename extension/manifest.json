{
  "manifest_version": 3,
  "name": "PromptLens",
  "version": "0.1.0",
  "description": "右键网页图片，弹出浮动窗口，反推 AI 绘图提示词。",
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "permissions": [
    "contextMenus",
    "storage",
    "sidePanel",
    "activeTab",
    "scripting",
    "downloads",
    "notifications",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },
  "options_page": "src/options/options.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "PromptLens - 点击打开面板"
  },
  "short_name": "PromptLens"
}
